# Database
DATABASE_URL=postgresql://magiclens:magiclens@localhost:5432/magiclens?schema=public
POSTGRES_USER=magiclens
POSTGRES_PASSWORD=magiclens
POSTGRES_DB=magiclens
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# API
API_PORT=3000
API_BASE_URL=http://localhost:3000
DESKTOP_CALLBACK_URL=magiclens://auth/callback
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars!!
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!
JWT_REFRESH_TTL=7d

# Google OAuth (leave empty to use local dev login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Encryption (32-byte base64 key for local only)
ENCRYPTION_MASTER_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# SMTP / Mailpit
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="MagicLens <noreply@magiclens.local>"
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# Invitations
INVITATION_TTL_HOURS=72
INVITATION_ACCEPT_URL=http://localhost:5173/invitations/accept

# Worker concurrency
WORKER_CONCURRENCY_EMAIL=5
WORKER_CONCURRENCY_CLUSTER_HEALTH=2
WORKER_CONCURRENCY_NOTIFICATIONS=5
WORKER_CONCURRENCY_MAINTENANCE=1

# Logging
LOG_LEVEL=info
NODE_ENV=development

# Admin UI
ADMIN_PORT=5173
VITE_API_BASE_URL=http://localhost:3000
