{
  "name": "magiclens",
  "productName": "MagicLens",
  "version": "0.1.12",
  "buildNumber": "13",
  "description": "A simple, fast Kubernetes cluster manager",
  "main": "./out/main/index.js",
  "author": {
    "name": "MagicLens",
    "email": "support@magicorn.co"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/magicorntech/magiclens.git"
  },
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "postinstall": "node -e \"if (process.env.SKIP_ELECTRON_REBUILD || process.env.DOCKER) process.exit(0); try { require('child_process').execSync('electron-rebuild -f -w node-pty', {stdio:'inherit'}); } catch (e) { console.warn('electron-rebuild skipped:', e.message); process.exit(0); }\"",
    "dist": "npm run build && electron-builder --publish never",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "dist:linux": "npm run build && electron-builder --linux --publish never",
    "release": "npm run build && electron-builder --publish always",
    "dev:api": "npm run start:dev -w @magiclens/api",
    "dev:worker": "npm run start:dev -w @magiclens/worker",
    "dev:admin": "npm run dev -w @magiclens/admin",
    "dev:desktop": "electron-vite dev",
    "dev:infra": "docker compose up -d postgres redis mailpit",
    "dev:infra:down": "docker compose stop postgres redis mailpit",
    "dev:backend": "npm run prisma:generate && npm run prisma:migrate && npm run prisma:seed && concurrently -k -n api,worker,admin -c teal,magenta,cyan \"npm run dev:api\" \"npm run dev:worker\" \"npm run dev:admin\"",
    "prisma:generate": "npm run prisma:generate -w @magiclens/database",
    "prisma:migrate": "npm run prisma:migrate -w @magiclens/database",
    "prisma:seed": "npm run prisma:seed -w @magiclens/database",
    "prisma:reset": "PRISMA_SEED_FORCE_RESET=1 npm run prisma:seed",
    "test:backend": "npm run test -w @magiclens/api && npm run test -w @magiclens/auth"
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.2",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/search": "^6.7.1",
    "@dagrejs/dagre": "^3.0.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@kubernetes/client-node": "1.4.0",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "5.101.2",
    "@uiw/codemirror-theme-github": "^4.25.10",
    "@uiw/react-codemirror": "^4.25.10",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.11.2",
    "antd": "6.5.0",
    "dayjs": "^1.11.13",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "framer-motion": "^12.42.2",
    "i18next": "^26.3.6",
    "lucide-react": "^1.23.0",
    "monaco-editor": "^0.55.1",
    "monaco-yaml": "^5.5.1",
    "node-pty": "^1.1.0",
    "prop-types": "^15.8.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-easy-crop": "^6.1.0",
    "react-i18next": "^17.0.10",
    "react-simple-maps": "^3.0.0",
    "recharts": "^3.9.2",
    "yaml": "^2.6.1",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.1.0",
    "@types/dagre": "^0.7.54",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/react-simple-maps": "^3.0.6",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.4",
    "electron": "^43.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "5.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
